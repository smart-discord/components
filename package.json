{
  "name": "@smart-discord/components",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smart-discord/components.git"
  },
  "main": "dist/index.js",
  "module": "src/index.ts",
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "prettier": "^3.8.3"
  },
  "peerDependencies": {
    "discord.js": "^14.26.4",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "bun run build:code && bun run build:declaration",
    "build:code": "bun build --target=node --packages=external ./src/index.ts --outfile=dist/index.js",
    "build:declaration": "tsc -p tsconfig.types.json",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "type": "module",
  "types": "dist/index.d.ts"
}
